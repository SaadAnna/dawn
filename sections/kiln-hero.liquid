<section class="relative overflow-hidden bg-[#c78f45] min-h-screen">

  <!-- Background -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#ecbc72] via-[#cdb99f] to-[#b9783e]"></div>

    <!-- light beam -->
    <div class="absolute top-0 right-0 w-[70%] h-full bg-white/20 blur-[120px] rotate-[-20deg]"></div>
  </div>

  <!-- NAV -->
  <div class="relative z-20 max-w-7xl mx-auto px-8 py-8 flex items-center justify-between">

    <h2 class="text-3xl font-extrabold text-white">
      Klin
    </h2>

    <div class="hidden md:flex items-center gap-10 text-white text-sm">
      <a href="#">Home</a>
      <a href="#">Menu</a>
      <a href="#">Delivery</a>
    </div>

    <div class="flex items-center gap-6 text-white text-xl">
      ♡
      👤
      🛒
    </div>

  </div>

  <!-- HERO -->
  <div class="relative z-10 h-[85vh] flex items-center justify-center">

    <!-- LEFT TEXT -->
    <h1 class="absolute left-8 md:left-24 text-[58px] md:text-[95px] font-extrabold uppercase tracking-tight text-white leading-none">
      ORDER
    </h1>

    <!-- RIGHT TEXT -->
    <div class="absolute right-8 md:right-24 text-right">

      <h1 class="text-[58px] md:text-[95px] font-extrabold uppercase text-white leading-none">
        COFFEE
      </h1>

      <p class="text-white italic text-4xl -mt-4">
        Welcome
      </p>

    </div>

    <!-- CENTER IMAGE -->
    <div class="relative">

      <img
        src="{{ section.settings.image | default: 'https://i.pinimg.com/control1/736x/86/1e/e0/861ee0bc2dfe4e245326367c020bab15.jpg' }}"
        alt="Coffee"
        class="w-[260px] md:w-[420px] object-contain drop-shadow-[0_30px_50px_rgba(0,0,0,.45)]"
        loading="eager"
        width="420" height="420"
      >

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Coffee Hero",
  "settings": [
    {
      "type":"image_picker",
      "id":"image",
      "label":"Hero Image"
    }
  ],
  "presets":[
    {
      "name":"Coffee Hero"
    }
  ]
}
{% endschema %}