<section class="relative overflow-hidden bg-kiln-bg pt-24 pb-32 md:pt-32 md:pb-40">
  <div class="absolute top-20 right-10 w-72 h-72 rounded-full bg-kiln-cream blur-3xl opacity-60 animate-float"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 rounded-full bg-[#EBE3D3] blur-3xl opacity-50 animate-float" style="animation-delay:-3s"></div>

  <div class="relative max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal">
      <p class="text-sm tracking-[0.3em] uppercase text-kiln-accent mb-6">{{ section.settings.eyebrow }}</p>
      <h1 class="text-5xl md:text-7xl font-light leading-[1.05] text-kiln-ink mb-8">{{ section.settings.heading }}</h1>
      <p class="text-lg text-kiln-muted max-w-md mb-10 leading-relaxed">{{ section.settings.subheading }}</p>
      <a href="{{ section.settings.button_link }}" class="inline-block bg-kiln-ink text-white px-10 py-4 text-sm tracking-wider uppercase transition-transform duration-500 hover:-translate-y-1">
        {{ section.settings.button_label }}
      </a>
    </div>

    <div class="relative reveal" style="transition-delay:.2s">
      <div class="tilt-3d relative">
        <img src="{{ section.settings.image | default: 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=1200' }}"
             alt="Kiln coffee" class="w-full h-[560px] object-cover shadow-2xl" loading="eager">
      </div>
      <div class="absolute -bottom-8 -left-8 bg-white px-8 py-6 shadow-xl">
        <p class="text-3xl font-light">100%</p>
        <p class="text-xs tracking-widest text-red-400 uppercase text-kiln-muted mt-1">Single Origin</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kiln Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Roasted with intent" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Coffee, quietly perfected." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Small-batch beans, slow-roasted in our neighborhood kiln. A cup that tastes like where it came from." },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Shop coffee" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [{ "name": "Kiln Hero" }]
}
{% endschema %}
