<section class="py-24 md:py-32 bg-kiln-cream">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <div class="reveal order-2 md:order-1">
      <div class="tilt-3d relative">
        <img src="{{ section.settings.image | default: 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1000' }}"
             alt="Our story" class="w-full h-[600px] object-cover shadow-2xl" loading="lazy">
      </div>
    </div>
    <div class="reveal order-1 md:order-2" style="transition-delay:.2s">
      <p class="text-xs tracking-[0.3em] uppercase text-kiln-accent mb-6">Our story</p>
      <h2 class="text-4xl md:text-5xl font-light leading-tight text-kiln-ink mb-8">{{ section.settings.heading }}</h2>
      <div class="space-y-5 text-kiln-muted leading-relaxed">{{ section.settings.body }}</div>
      <div class="mt-12 grid grid-cols-3 gap-6 pt-8 border-t border-kiln-line">
        <div><p class="text-3xl font-light">2019</p><p class="text-xs tracking-widest uppercase text-kiln-muted mt-1">Founded</p></div>
        <div><p class="text-3xl font-light">12</p><p class="text-xs tracking-widest uppercase text-kiln-muted mt-1">Origins</p></div>
        <div><p class="text-3xl font-light">1M+</p><p class="text-xs tracking-widest uppercase text-kiln-muted mt-1">Cups poured</p></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kiln Story",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built in a small room. Poured into every cup." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Kiln started with one roaster, one bag of beans, and a stubborn belief that coffee should taste like the place it grew.</p><p>Today we still roast every batch by hand, in the same small room, with the same stubborn belief.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [{ "name": "Kiln Story" }]
}
{% endschema %}
