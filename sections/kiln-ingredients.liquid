<section class="py-24 md:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-20 reveal">
      <p class="text-xs tracking-[0.3em] uppercase text-kiln-accent mb-4">The Craft</p>
      <h2 class="text-4xl md:text-5xl font-light text-kiln-ink">Four things. Nothing else.</h2>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {% for block in section.blocks %}
        <div class="reveal text-center" style="transition-delay: {{ forloop.index0 | times: 100 }}ms">
          <div class="tilt-3d aspect-square mb-6 bg-kiln-cream overflow-hidden">
            <img src="{{ block.settings.image | default: 'https://images.unsplash.com/photo-1447933601403-0c6688de566e?w=600' }}"
                 alt="{{ block.settings.title }}" class="w-full h-full object-cover" loading="lazy">
          </div>
          <p class="text-xs tracking-[0.2em] uppercase text-kiln-muted mb-2">0{{ forloop.index }}</p>
          <h3 class="text-lg font-medium text-kiln-ink mb-2">{{ block.settings.title }}</h3>
          <p class="text-sm text-kiln-muted leading-relaxed">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kiln Ingredients",
  "blocks": [{
    "type": "item", "name": "Ingredient",
    "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "Arabica Beans" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Ethically sourced from single-origin farms in Ethiopia and Colombia." }
    ]
  }],
  "max_blocks": 6,
  "presets": [{
    "name": "Kiln Ingredients",
    "blocks": [
      { "type": "item", "settings": { "title": "Arabica Beans", "text": "Ethically sourced from single-origin farms." }},
      { "type": "item", "settings": { "title": "Spring Water", "text": "Filtered, mineral-balanced, at 92°C." }},
      { "type": "item", "settings": { "title": "Slow Roast", "text": "18 minutes in our neighborhood kiln." }},
      { "type": "item", "settings": { "title": "Fresh Milk", "text": "Local dairy, delivered every morning." }}
    ]
  }]
}
{% endschema %}
